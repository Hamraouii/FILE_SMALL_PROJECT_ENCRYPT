
<!-- views/users.ejs -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users Directory - Secure File Encryption</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <div class="container mt-4">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h3>Users Directory</h3>
                        </div>
                        <div class="card-body">
                            <p>Below is a list of all users and their public keys. You can use these public keys to
                                encrypt files for specific users.</p>

                            <div class="table-responsive">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Public Key</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% users.forEach(function(user) { %>
                                            <tr>
                                                <td>
                                                    <%= user.name %>
                                                </td>
                                                <td>
                                                    <%= user.email %>
                                                </td>
                                                <td>
                                                    <% if (user.publicKey) { %>
                                                        <button class="btn btn-sm btn-outline-primary view-public-key"
                                                            data-bs-toggle="modal" data-bs-target="#publicKeyModal"
                                                            data-public-key="<%= user.publicKey %>">View Public
                                                            Key</button>
                                                        <% } else { %>
                                                            <span class="badge bg-warning text-dark">No public
                                                                key</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <% if (user.publicKey) { %>
                                                        <a href="/encrypt?recipient=<%= user._id %>"
                                                            class="btn btn-sm btn-primary">Encrypt for User</a>
                                                        <% } %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Public Key Modal -->
        <div class="modal fade" id="publicKeyModal" tabindex="-1" aria-labelledby="publicKeyModalLabel"
            aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="publicKeyModalLabel">User Public Key</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <textarea id="modalPublicKey" class="form-control" rows="10" readonly></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary" id="copyPublicKey">Copy to Clipboard</button>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Handle viewing public keys
                const viewButtons = document.querySelectorAll('.view-public-key');
                const modalPublicKey = document.getElementById('modalPublicKey');
                const copyButton = document.getElementById('copyPublicKey');

                viewButtons.forEach(button => {
                    button.addEventListener('click', function () {
                        const publicKey = this.getAttribute('data-public-key');
                        modalPublicKey.value = publicKey;
                    });
                });

                // Copy public key to clipboard
                copyButton.addEventListener('click', function () {
                    modalPublicKey.select();
                    document.execCommand('copy');
                    this.innerText = 'Copied!';
                    setTimeout(() => {
                        this.innerText = 'Copy to Clipboard';
                    }, 2000);
                });
            });
        </script>
</body>

</html>
